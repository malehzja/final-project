    {
      "cell_type": "markdown",
      "metadata": {
        "id": "c5640a03"
      },
      "source": [
        "Now that the data for the selected topics has been prepared in a DataFrame, we will use `seaborn.catplot` to create a facet bar graph visualizing the top 10 words and their probabilities for each of the specified topics (2, 5, 10, and 15)."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 834
        },
        "id": "25de30ef",
        "outputId": "286e7ca9-1384-4eb9-adf6-23d3e964cadb"
      },
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Create the facet bar plot\n",
        "g = sns.catplot(data=df_topic_words, x='Word', y='Probability', col='Topic ID', col_wrap=2, kind='bar',\n",
        "                height=4, aspect=2, hue='Word', legend=False, palette='twilight', sharex=False, sharey=False)\n",
        "\n",
        "# Customize the plot\n",
        "g.set_axis_labels(\"Word\", \"Probability\")\n",
        "g.set_titles(\"Topic {col_name}\")\n",
        "\n",
        "# Rotate x-axis labels for better readability\n",
        "for ax in g.axes.flat:\n",
        "    for label in ax.get_xticklabels():\n",
        "        label.set_rotation(45)\n",
        "    ax.tick_params(axis='x', labelbottom=True)\n",
        "\n",
        "plt.suptitle('Top Words and Probabilities for Selected Topics', y=1.02, fontsize=16)\n",
        "plt.tight_layout(rect=[0, 0.03, 1, 0.98])\n",
        "plt.show()"
      ],
